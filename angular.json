{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "projects": {
    "@rero/ng-core": {
      "projectType": "library",
      "root": "projects/rero/ng-core",
      "sourceRoot": "projects/rero/ng-core/src",
      "prefix": "ng-core",
      "architect": {
        "build": {
          "builder": "@angular/build:ng-packagr",
          "options": {
            "tsConfig": "projects/rero/ng-core/tsconfig.lib.json",
            "project": "projects/rero/ng-core/ng-package.json"
          },
          "configurations": {
            "production": {
              "tsConfig": "projects/rero/ng-core/tsconfig.lib.prod.json"
            }
          }
        },
        "test": {
          "builder": "@angular/build:unit-test",
          "options": {
            "buildTarget": "ng-core-tester:build",
            "browsers": ["chromium"],
            "tsConfig": "projects/rero/ng-core/tsconfig.spec.json"
          }
        },
        "lint": {
          "builder": "@angular-eslint/builder:lint",
          "options": {
            "lintFilePatterns": ["projects/rero/ng-core/src/**/*.ts", "projects/rero/ng-core/src/**/*.html"]
          }
        }
      }
    },
    "ng-core-tester": {
      "projectType": "application",
      "root": "projects/ng-core-tester",
      "sourceRoot": "projects/ng-core-tester/src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "allowedCommonJsDependencies": ["crypto-js", "easymde", "js-generate-password"],
            "outputPath": {
              "base": "dist/ng-core-tester"
            },
            "index": "projects/ng-core-tester/src/index.html",
            "polyfills": ["zone.js"],
            "tsConfig": "projects/ng-core-tester/tsconfig.app.json",
            "assets": ["projects/ng-core-tester/src/favicon.ico", "projects/ng-core-tester/src/assets"],
            "styles": ["projects/ng-core-tester/src/styles.scss"],
            "stylePreprocessorOptions": {
              "includePaths": ["projects/rero/ng-core/assets/scss"]
            },
            "extractLicenses": false,
            "sourceMap": true,
            "optimization": false,
            "namedChunks": true,
            "browser": "projects/ng-core-tester/src/main.ts"
          },
          "configurations": {
            "production": {
              "fileReplacements": [
                {
                  "replace": "projects/ng-core-tester/src/environments/environment.ts",
                  "with": "projects/ng-core-tester/src/environments/environment.prod.ts"
                }
              ],
              "optimization": true,
              "outputHashing": "all",
              "sourceMap": false,
              "namedChunks": false,
              "extractLicenses": true,
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "2mb",
                  "maximumError": "5mb"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "6kb"
                }
              ]
            }
          },
          "defaultConfiguration": ""
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "options": {
            "buildTarget": "ng-core-tester:build"
          },
          "configurations": {
            "localhost": {
              "proxyConfig": "proxies/localhost.json"
            },
            "wiremockapi": {
              "proxyConfig": "proxies/wiremockapi.json"
            },
            "production": {
              "buildTarget": "ng-core-tester:build:production"
            }
          }
        },
        "extract-i18n": {
          "builder": "@angular/build:extract-i18n",
          "options": {
            "buildTarget": "ng-core-tester:build"
          }
        },
        "test": {
          "builder": "@angular/build:unit-test",
          "options": {
            "buildTarget": "ng-core-tester:build",
            "browsers": ["chromium"],
            "tsConfig": "projects/ng-core-tester/tsconfig.spec.json"
          }
        },
        "lint": {
          "builder": "@angular-eslint/builder:lint",
          "options": {
            "lintFilePatterns": ["projects/ng-core-tester/src/**/*.ts", "projects/ng-core-tester/src/**/*.html"]
          }
        }
      }
    }
  },
  "schematics": {
    "@schematics/angular:component": {
      "type": "component"
    },
    "@schematics/angular:directive": {
      "type": "directive"
    },
    "@schematics/angular:service": {
      "type": "service"
    },
    "@schematics/angular:guard": {
      "typeSeparator": "."
    },
    "@schematics/angular:interceptor": {
      "typeSeparator": "."
    },
    "@schematics/angular:module": {
      "typeSeparator": "."
    },
    "@schematics/angular:pipe": {
      "typeSeparator": "."
    },
    "@schematics/angular:resolver": {
      "typeSeparator": "."
    }
  }
}
